{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/pipelines/[pipelineId]",
      "regex": "^/api/pipelines/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPpipelineId": "nxtPpipelineId"
      },
      "namedRegex": "^/api/pipelines/(?<nxtPpipelineId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/pipelines/[pipelineId]/runs",
      "regex": "^/api/pipelines/([^/]+?)/runs(?:/)?$",
      "routeKeys": {
        "nxtPpipelineId": "nxtPpipelineId"
      },
      "namedRegex": "^/api/pipelines/(?<nxtPpipelineId>[^/]+?)/runs(?:/)?$"
    },
    {
      "page": "/api/runs/[runId]/cancel",
      "regex": "^/api/runs/([^/]+?)/cancel(?:/)?$",
      "routeKeys": {
        "nxtPrunId": "nxtPrunId"
      },
      "namedRegex": "^/api/runs/(?<nxtPrunId>[^/]+?)/cancel(?:/)?$"
    },
    {
      "page": "/pipelines/[pipelineId]",
      "regex": "^/pipelines/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPpipelineId": "nxtPpipelineId"
      },
      "namedRegex": "^/pipelines/(?<nxtPpipelineId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/runs/[runId]",
      "regex": "^/runs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPrunId": "nxtPrunId"
      },
      "namedRegex": "^/runs/(?<nxtPrunId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/pipelines",
      "regex": "^/api/pipelines(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/pipelines(?:/)?$"
    },
    {
      "page": "/api/stream",
      "regex": "^/api/stream(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/stream(?:/)?$"
    },
    {
      "page": "/pipelines",
      "regex": "^/pipelines(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pipelines(?:/)?$"
    },
    {
      "page": "/pipelines/new",
      "regex": "^/pipelines/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pipelines/new(?:/)?$"
    },
    {
      "page": "/runs",
      "regex": "^/runs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/runs(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}